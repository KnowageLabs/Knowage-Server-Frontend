# Name of the HTTP header used to pass the authentication token in API requests
VITE_DEFAULT_AUTH_HEADER = X-Kn-Authorization

# Whether the application is served over HTTPS (true) or HTTP (false)
VITE_HOST_HTTPS = false

# Base URL prefix for the application (leave empty if served at root)
VITE_BASE_URL = 

# URL of the backend Knowage server (used by the dev proxy to forward API requests)
VITE_HOST_URL = http://127.0.0.1:8080

# Maximum allowed file size (in bytes) for image uploads
VITE_MAX_UPLOAD_IMAGE_SIZE = 200000

# Duration (in milliseconds) that toast notification messages are displayed
VITE_TOAST_DURATION = 5000

# Public base path where the Vue frontend is served
VITE_PUBLIC_PATH = /knowage-vue/

# WebSocket endpoint path used for real-time communication with the server
VITE_WEBSOCKET_URL =  knowage/webSocket

# i18n key prefix used to look up form validation error messages
VITE_VALIDATION_MESSAGES_BASE_KEY = common.validation

# Context path for the Knowage REST API backend
VITE_KNOWAGE_API_CONTEXT = /knowage-api

# Context path for the main Knowage web application
VITE_KNOWAGE_CONTEXT = /knowage

# Context path for the Knowage Vue frontend application
VITE_KNOWAGE_VUE_CONTEXT = /knowage-vue

# Context path for the Cockpit engine (cockpit widgets)
VITE_KNOWAGECOCKPITENGINE_CONTEXT = /knowagecockpitengine

# Context path for the Data Preparation module
VITE_KNOWAGE_DATA_PREPARATION_CONTEXT = /knowage-data-preparation

# Context path for the Dossier engine (PDF/PPT report generation)
VITE_KNOWAGEDOSSIER_CONTEXT = /knowagedossierengine

# Context path for the What-If analysis engine
VITE_KNOWAGEWHATIF_CONTEXT = /knowagewhatifengine

# Context path for the Query By Example (QBE) engine
VITE_KNOWAGEQBE_CONTEXT = /knowageqbeengine

# Context path for the Knowage Metadata module
VITE_KNOWAGEMETA_CONTEXT = /knowagemeta

# Context path for the KPI (Key Performance Indicator) engine
VITE_KNOWAGEKPIENGINE_CONTEXT = /knowagekpiengine

# Time (in milliseconds) before the main menu fades out after losing focus
VITE_MENU_FADE_TIMER = 2000

# Whether to use the legacy QBE interface rendered inside an iframe (true) or the new Vue-based one (false)
VITE_USE_OLD_QBE_IFRAME = false

# Date format string used when passing date values in cross-navigation parameters
VITE_CROSS_NAVIGATION_DATE_FORMAT = yyyy-MM-dd

# User session timeout duration in milliseconds (default: 30 minutes)
VITE_SESSION_TIMEOUT = 1800000
